{
  "compilerOptions": {
    "noEmitOnError": false,
    "diagnostics": true,
    "lib": ["esnext"],
    "types": ["node"],

    "rootDir": "./src",
    "target": "es2020",

    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "module": "esnext",
    "esModuleInterop": true,

    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true
  },
  "exclude": ["dist"]
}
